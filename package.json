{
  "name": "flat-embed-monorepo",
  "private": true,
  "description": "Flat Embed SDK monorepo",
  "license": "Apache-2.0",
  "author": "Flat Team <developers@flat.io>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FlatIO/embed-client.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "biome:check": "biome check .",
    "biome:fix": "biome check --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm -r build && changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@changesets/cli": "^2.30.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.5",
    "typescript": "^5.8.3"
  }
}
